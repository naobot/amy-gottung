{
  "assets_path": "assets/uploads",
  "data_path": "_data",
  "collections": [
    {
      "name": "works",
      "label": "Works",
      "path": "_works",
      "orderable": true,
      "publishable": true,
      "fields": [
        { "name": "title", "label": "Title", "type": "text", "required": true },
        { "name": "link", "label": "External Project Link", "type": "text", "required": false },
        { "name": "client", "label": "Client", "type": "text", "required": false },
        { "name": "client_link", "label": "Client Link", "type": "text", "required": false },
        { "name": "role", "label": "Role", "type": "text", "required": false },
        { "name": "when", "label": "When", "type": "text", "required": false },
        { "name": "where", "label": "Where", "type": "textarea", "required": false },
        { "name": "team", "label": "Team", "type": "textarea", "required": false },
        { "name": "partners", "label": "Partners", "type": "rich-text", "required": false },
        { "name": "categories", "label": "Category", "type": "multiselect", "options": ["creative", "consulting", "speaking", "writing"], "required": false },
        { "name": "tags", "label": "Tags", "type": "multiselect", "data_file": "_data/tags.json", "required": false },
        { "name": "thumbnail", "label": "Main Image", "type": "image", "required": false },
        { "name": "images", "label": "Additional Images", "type": "image-list", "required": false }
      ]
    }
  ],
  "singletons": [
    {
      "name": "index",
      "label": "Home",
      "path": "_pages/index.md",
      "fields": [
        { "name": "title", "label": "Title", "type": "text", "required": true }
      ]
    },
    {
      "name": "clients",
      "label": "Client Roster",
      "path": "_pages/clients.md",
      "fields": [
        { "name": "title", "label": "Title", "type": "text", "required": true }
      ]
    }
  ],
  "data_files": [
    {
      "path": "_data/site_config.yml",
      "label": "Site Config",
      "fields": [
        {
          "name": "info",
          "label": "Info",
          "type": "object",
          "fields": [
            { "name": "title", "label": "Title", "type": "text" },
            { "name": "short_bio", "label": "Short Bio", "type": "textarea" },
            { "name": "email", "label": "Email", "type": "text" }
          ]
        },
        {
          "name": "settings",
          "label": "Settings",
          "type": "object",
          "fields": [
            { "name": "construction_text", "label": "Construction Text", "type": "text" }
          ]
        },
        {
          "name": "categories",
          "label": "Categories",
          "type": "list",
          "required": false
        }
      ]
    },
    {
      "path": "_data/about.yml",
      "label": "About",
      "fields": [
        { "name": "photo", "label": "Photo", "type": "image", "required": false },
        { "name": "top_left", "label": "Top Left Box", "type": "textarea", "required": false },
        { "name": "top_right", "label": "Top Right Box", "type": "textarea", "required": false },
        { "name": "main", "label": "Main Content", "type": "textarea", "required": false }
      ]
    },
    {
      "path": "_data/navigation.yml",
      "label": "Navigation",
      "fields": [
        {
          "name": "items",
          "label": "Navigation Items",
          "type": "list-of-objects",
          "fields": [
            { "name": "name", "label": "Name", "type": "text", "required": true },
            { "name": "link", "label": "Link", "type": "text", "required": true }
          ]
        }
      ]
    },
    { "path": "_data/tags.json", "label": "Tags" }
  ]
}